# ========================================
# REQUIRED - Google OAuth Credentials
# ========================================
# Create these at https://console.cloud.google.com/apis/credentials
# See the in-app Setup Guide (visit /setup) for full step-by-step instructions.

GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback


# ========================================
# OPTIONAL - Session Secret
# ========================================
# A random string used to sign session cookies. If left blank, a new random
# value is generated each time the app starts (which logs you out on every restart).
# Set this to keep sessions persistent across restarts.
# Generate one with:  openssl rand -hex 32

# SESSION_SECRET=


# ========================================
# OPTIONAL - PostgreSQL Database
# ========================================
# Only needed for hosted deployments (e.g. Replit with Neon Postgres).
# When this is unset, the app automatically uses SQLite (calendar.db) which is
# the recommended setup for self-hosted Raspberry Pi installations.

# DATABASE_URL=postgresql://user:password@host:5432/dbname


# ========================================
# OPTIONAL - GitHub Repository (for auto-update)
# ========================================
# These tell the auto-updater where to look for new releases on GitHub.
# Defaults: GITHUB_REPO_OWNER=YOUR_GITHUB_USERNAME, GITHUB_REPO_NAME=mcmurry-hurricane-calendar
# Set these to point at YOUR fork if you renamed the repo or use a different account.

# GITHUB_REPO_OWNER=your-github-username
# GITHUB_REPO_NAME=your-repo-name


# ========================================
# OPTIONAL - Node Environment
# ========================================
# NODE_ENV=production
