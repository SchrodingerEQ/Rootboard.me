# ========================================
# REQUIRED - Google Service Account
# ========================================
# Setup steps:
# 1. Go to https://console.cloud.google.com/iam-admin/serviceaccounts
# 2. Create a new service account (name it anything, e.g. "calendar-kiosk")
# 3. Enable the Google Calendar API for your project
# 4. Create a JSON key for the service account: Actions → Manage keys → Add key → JSON
# 5. Download the JSON key file and copy it to this directory on the Pi
# 6. Share each Google Calendar you want displayed with the service account's email
#    address (the "client_email" field in the JSON key file).
#    Use "Make changes to events" permission to allow future event creation.
#
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json


# ========================================
# OPTIONAL - PostgreSQL Database
# ========================================
# Only needed for hosted deployments (e.g. Replit with Neon Postgres).
# When this is unset, the app automatically uses SQLite (calendar.db) which is
# the recommended setup for self-hosted Raspberry Pi installations.

# DATABASE_URL=postgresql://user:password@host:5432/dbname


# ========================================
# OPTIONAL - GitHub Repository (for auto-update)
# ========================================
# These tell the auto-updater where to look for new releases on GitHub.
# Defaults: GITHUB_REPO_OWNER=YOUR_GITHUB_USERNAME, GITHUB_REPO_NAME=mcmurry-hurricane-calendar
# Set these to point at YOUR fork if you renamed the repo or use a different account.

# GITHUB_REPO_OWNER=your-github-username
# GITHUB_REPO_NAME=your-repo-name


# ========================================
# OPTIONAL - Node Environment
# ========================================
# NODE_ENV=production
