# Shell scripts must use LF line endings so they execute correctly on Linux
# (e.g. the Raspberry Pi) even when the repo is checked out or edited on Windows.
# Without this, Git's autocrlf can introduce CRLF, which breaks `start.sh` both
# on the Pi and in the auto-update flow (the updater runs start.sh from the
# downloaded release tarball).
*.sh text eol=lf

# Git hooks are executed by /bin/sh on Linux/macOS — must stay LF.
.githooks/* text eol=lf
